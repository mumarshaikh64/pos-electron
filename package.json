{
  "name": "medical-pos",
  "version": "0.1.0",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:renderer": "next dev",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build:db": "cross-env DATABASE_URL=\"file:./prisma/dev.db\" prisma db push && cross-env DATABASE_URL=\"file:./prisma/dev.db\" tsx prisma/seed.ts",
    "build:renderer": "next build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:db && npm run build:main && npm run build:renderer",
    "start": "electron .",
    "lint": "eslint",
    "package": "electron-builder --win --dir"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "framer-motion": "^12.42.0",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.medicalpos.app",
    "productName": "MedicalPOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/**/*",
      {
        "from": "out",
        "to": "dist/renderer/out",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma"
      },
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma"
      },
      {
        "from": "node_modules/@prisma/client",
        "to": "node_modules/@prisma/client"
      },
      {
        "from": "node_modules/prisma",
        "to": "node_modules/prisma"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "overrides": {
    "app-builder-lib": {
      "@noble/hashes": "1.8.0"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
